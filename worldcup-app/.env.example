# Turso libSQL database connection
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# Admin identification — the user with this username (case-insensitive) has
# admin privileges. The username is reserved and cannot be self-registered.
ADMIN_USERNAME=

# Session cookie encryption key — minimum 32 characters. Rotating this
# invalidates all active sessions (forced re-login for every user).
# Generate one with: openssl rand -base64 48
SESSION_SECRET=
